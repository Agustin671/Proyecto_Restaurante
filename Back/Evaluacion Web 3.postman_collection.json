  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "if (jsonData.data && jsonData.data.accessToken) {\r",
              "    pm.collectionVariables.set(\"token\", jsonData.data.accessToken);\r",
              "    pm.test(\"Token guardado exitosamente\", function () {\r",
              "        pm.expect(true).to.be.true;\r",
              "    });\r",
              "} else {\r",
              "    pm.test(\"No se pudo obtener el token\", function () {\r",
              "        pm.expect(false).to.be.true;\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"agustin@test.com\",\r\n  \"password\": \"password123\",\r\n  \"nombre\": \"Agustín Cañas\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
